                      tile_trim = td$tile_trim,
                      r_target  = habitat,
                      r_mov     = affinity,
                      r_src     = habitat,
                      clear_dir = TRUE,
                      landmark  = td$landmark)

## Run ConScape on tiles
cs_res <- run_conscape(conscape_prep  = prep,
                       out_dir        = "conscape_out",
                       theta          = td$theta,
                       distance_scale = td$distance_scale,
                       jl_home        = jl_home)
